# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# DB
DATABASE_URL="file:./dev.db"

# Storage
STORAGE_DIR=./storage
AUDIO_TTL_HOURS=24

# Providers: mock | fasterwhisper (mvp defaults to fasterwhisper)
ASR_PROVIDER=fasterwhisper
# ASR_ENDPOINT is auto-injected by docker-compose (=http://asr:8000) or by
# scripts/dev.sh for the Apple `container` setup. For standalone dev outside
# any container, uncomment:
# ASR_ENDPOINT=http://localhost:8000
ASR_LANGUAGE=zh
LLM_PROVIDER=mock
IMAGE_PROVIDER=mock

# --- Docker Compose specific ---
# Host ports to publish (change if you have conflicts).
APP_PORT=3000
ASR_PORT=8000
# Whisper model settings (see services/asr/app.py).
WHISPER_MODEL=Systran/faster-whisper-small
WHISPER_COMPUTE_TYPE=int8
WHISPER_DEVICE=cpu
WHISPER_LANGUAGE=zh
# Where the huggingface hub cache lives on the host (mounted read-write into
# the asr container so first download is persisted).
HF_CACHE_DIR=~/.cache/huggingface
